diff --git a/src/d3d9/meson.build b/src/d3d9/meson.build
index 2f45946..37c0023 100644
--- a/src/d3d9/meson.build
+++ b/src/d3d9/meson.build
@@ -52,11 +52,20 @@ d3d9_src = [
 d3d9_ld_args      = []
 d3d9_link_depends = []
 
-if platform != 'windows'
+if platform != 'windows' and host_machine.system() != 'darwin'
+  # GNU ld only; Apple's ld64 has no --version-script (and the darwin build is static)
   d3d9_ld_args      += [ '-Wl,--version-script', join_paths(meson.current_source_dir(), 'd3d9.sym') ]
   d3d9_link_depends += files('d3d9.sym')
 endif
 
+if host_machine.system() == 'darwin'
+# iOS/macOS: a static archive — iOS app bundles link DXVK statically
+d3d9_dll = static_library(dxvk_name_prefix+'d3d9', d3d9_src, glsl_generator.process(d3d9_shaders), d3d9_res,
+  dependencies        : [ dxso_dep, dxvk_dep ],
+  include_directories : dxvk_include_path,
+  install             : true,
+)
+else
 d3d9_dll = shared_library(dxvk_name_prefix+'d3d9', d3d9_src, glsl_generator.process(d3d9_shaders), d3d9_res,
   dependencies        : [ dxso_dep, dxvk_dep ],
   include_directories : dxvk_include_path,
@@ -66,6 +75,7 @@ d3d9_dll = shared_library(dxvk_name_prefix+'d3d9', d3d9_src, glsl_generator.proc
   link_depends        : [ d3d9_link_depends ],
   kwargs              : dxvk_so_version,
 )
+endif
 
 d3d9_dep = declare_dependency(
   link_with           : [ d3d9_dll ],

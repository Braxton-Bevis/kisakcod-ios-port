diff --git a/tools/spikes/bmk4-slice6/Build-ZoneCodeGenerator.ps1 b/tools/spikes/bmk4-slice6/Build-ZoneCodeGenerator.ps1
new file mode 100644
index 0000000..5ab59c8
--- /dev/null
+++ b/tools/spikes/bmk4-slice6/Build-ZoneCodeGenerator.ps1
@@ -0,0 +1,56 @@
+param(
+    [Parameter(Mandatory = $true)]
+    [string] $ZigPath,
+
+    [string] $OutputPath = "build/bmk4-spike/ZoneCodeGenerator.exe"
+)
+
+$ErrorActionPreference = "Stop"
+
+$repoRoot = [System.IO.Path]::GetFullPath((Join-Path $PSScriptRoot "../../.."))
+$zig = [System.IO.Path]::GetFullPath((Join-Path (Get-Location) $ZigPath))
+$output = [System.IO.Path]::GetFullPath((Join-Path $repoRoot $OutputPath))
+$buildDirectory = Split-Path -Parent $output
+$generatedDirectory = Join-Path $buildDirectory "generated"
+
+if (-not (Test-Path -LiteralPath $zig -PathType Leaf)) {
+    throw "Zig executable does not exist: $zig"
+}
+
+New-Item -ItemType Directory -Force $buildDirectory, $generatedDirectory | Out-Null
+Set-Content -LiteralPath (Join-Path $generatedDirectory "GitVersion.h") -Encoding Ascii -Value @(
+    "#pragma once"
+    "#define GIT_VERSION `"a87850d-bmk4-spike`""
+)
+
+$env:ZIG_GLOBAL_CACHE_DIR = Join-Path $buildDirectory "zig-global-cache"
+$env:ZIG_LOCAL_CACHE_DIR = Join-Path $buildDirectory "zig-cache"
+
+$sourceRoots = @("src/Utils", "src/Parser", "src/ZoneCodeGeneratorLib", "src/ZoneCodeGenerator")
+$sources = foreach ($sourceRoot in $sourceRoots) {
+    Get-ChildItem -LiteralPath (Join-Path $repoRoot $sourceRoot) -Recurse -Filter *.cpp | ForEach-Object FullName
+}
+
+$arguments = @(
+    "c++",
+    "-std=c++23",
+    "-O2",
+    "-DNDEBUG",
+    "-DARCH_x64",
+    "-D__STDC_LIB_EXT1__",
+    "-D__STDC_WANT_LIB_EXT1__=1",
+    "-D_CRT_SECURE_NO_WARNINGS",
+    "-Wno-dll-attribute-on-redeclaration",
+    "-I$(Join-Path $repoRoot 'src/Utils')",
+    "-I$(Join-Path $repoRoot 'src/Parser')",
+    "-I$(Join-Path $repoRoot 'src/ZoneCodeGeneratorLib')",
+    "-I$(Join-Path $repoRoot 'src/ZoneCodeGenerator')",
+    "-I$generatedDirectory"
+) + $sources + @("-o", $output)
+
+& $zig @arguments
+if ($LASTEXITCODE -ne 0) {
+    throw "ZoneCodeGenerator build failed with exit code $LASTEXITCODE"
+}
+
+Write-Output "Built $output"
diff --git a/tools/spikes/bmk4-slice6/Verify-ZoneLayoutManifest.ps1 b/tools/spikes/bmk4-slice6/Verify-ZoneLayoutManifest.ps1
new file mode 100644
index 0000000..8bf98a9
--- /dev/null
+++ b/tools/spikes/bmk4-slice6/Verify-ZoneLayoutManifest.ps1
@@ -0,0 +1,76 @@
+param(
+    [string] $ZoneCodeGeneratorPath = "build/bmk4-spike/ZoneCodeGenerator.exe"
+)
+
+$ErrorActionPreference = "Stop"
+
+$repoRoot = [System.IO.Path]::GetFullPath((Join-Path $PSScriptRoot "../../.."))
+$generator = [System.IO.Path]::GetFullPath((Join-Path $repoRoot $ZoneCodeGeneratorPath))
+$testRoot = [System.IO.Path]::GetFullPath((Join-Path $repoRoot "build/bmk4-spike/golden-test"))
+$run1 = Join-Path $testRoot "run1"
+$run2 = Join-Path $testRoot "run2"
+$goldenRoot = Join-Path $repoRoot "test/ZoneCodeGeneratorLibTests/Golden/IW3/ZoneLayoutManifest"
+
+if (-not (Test-Path -LiteralPath $generator -PathType Leaf)) {
+    throw "ZoneCodeGenerator executable does not exist: $generator"
+}
+
+$expectedBuildRoot = [System.IO.Path]::GetFullPath((Join-Path $repoRoot "build")) + [System.IO.Path]::DirectorySeparatorChar
+if (-not ($testRoot + [System.IO.Path]::DirectorySeparatorChar).StartsWith($expectedBuildRoot, [System.StringComparison]::OrdinalIgnoreCase)) {
+    throw "Refusing to clean a test path outside the build directory: $testRoot"
+}
+
+if (Test-Path -LiteralPath $testRoot) {
+    Remove-Item -LiteralPath $testRoot -Recurse -Force
+}
+
+function Invoke-Generation([string] $outputDirectory) {
+    & $generator `
+        --no-color `
+        -h (Join-Path $repoRoot "src/ZoneCode/Game/IW3/IW3_ZoneCode.h") `
+        -c (Join-Path $repoRoot "src/ZoneCode/Game/IW3/IW3_Commands.txt") `
+        -o $outputDirectory `
+        -g ZoneLayoutManifest
+
+    if ($LASTEXITCODE -ne 0) {
+        throw "ZoneLayoutManifest generation failed with exit code $LASTEXITCODE"
+    }
+}
+
+function Assert-ByteIdentical([string] $expected, [string] $actual) {
+    $difference = Compare-Object `
+        (Get-Content -LiteralPath $expected -Encoding Byte -ReadCount 0) `
+        (Get-Content -LiteralPath $actual -Encoding Byte -ReadCount 0)
+    if ($null -ne $difference) {
+        throw "Files are not byte-identical: $expected and $actual"
+    }
+}
+
+Invoke-Generation $run1
+Invoke-Generation $run2
+
+$manifestRoot1 = Join-Path $run1 "ZoneLayoutManifest/iw3"
+$manifestRoot2 = Join-Path $run2 "ZoneLayoutManifest/iw3"
+$relativeFiles1 = Get-ChildItem -LiteralPath $manifestRoot1 -File | ForEach-Object Name | Sort-Object
+$relativeFiles2 = Get-ChildItem -LiteralPath $manifestRoot2 -File | ForEach-Object Name | Sort-Object
+
+if (Compare-Object $relativeFiles1 $relativeFiles2) {
+    throw "The two runs produced different manifest file sets"
+}
+
+foreach ($relativeFile in $relativeFiles1) {
+    Assert-ByteIdentical (Join-Path $manifestRoot1 $relativeFile) (Join-Path $manifestRoot2 $relativeFile)
+}
+
+$goldenFiles = @("iw3_rawfile.layout", "iw3_menudef_t.layout")
+foreach ($goldenFile in $goldenFiles) {
+    $generated = Join-Path $manifestRoot1 $goldenFile
+    $golden = Join-Path $goldenRoot $goldenFile
+    Assert-ByteIdentical $golden $generated
+
+    $hash = (Get-FileHash -LiteralPath $generated -Algorithm SHA256).Hash.ToLowerInvariant()
+    $structureCount = (Select-String -LiteralPath $generated -Pattern '^structure "').Count
+    Write-Output "PASS $goldenFile structures=$structureCount sha256=$hash"
+}
+
+Write-Output "PASS all $($relativeFiles1.Count) IW3 manifests were byte-identical across two independent output directories"

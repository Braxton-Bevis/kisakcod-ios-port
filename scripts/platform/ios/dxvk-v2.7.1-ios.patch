+#pragma once
+
+#include <windows.h>
+
+#ifdef __OBJC__
+@class CAMetalLayer;
+#else
+typedef void CAMetalLayer;
+#endif
+
+namespace dxvk::wsi {
+
+  // On iOS the HWND is a CAMetalLayer* owned by the app shell.
+
+  inline CAMetalLayer* fromHwnd(HWND hWindow) {
+    return reinterpret_cast<CAMetalLayer*>(hWindow);
+  }
+
+  inline HWND toHwnd(CAMetalLayer* pLayer) {
+    return reinterpret_cast<HWND>(pLayer);
+  }
+
+}

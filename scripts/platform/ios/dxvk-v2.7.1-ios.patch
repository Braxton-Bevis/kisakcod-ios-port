diff --git a/src/wsi/ios/wsi_monitor_ios.mm b/src/wsi/ios/wsi_monitor_ios.mm
new file mode 100644
index 0000000..ae5fdd1
--- /dev/null
+++ b/src/wsi/ios/wsi_monitor_ios.mm
@@ -0,0 +1,108 @@
+#if defined(DXVK_WSI_IOS)
+
+#include "../wsi_monitor.h"
+
+#include "wsi_platform_ios.h"
+
+#include "../../util/log/log.h"
+
+#include <cstring>
+#include <string>
+
+namespace dxvk::wsi {
+
+  HMONITOR IosWsiDriver::getDefaultMonitor() {
+    return enumMonitors(0);
+  }
+
+
+  HMONITOR IosWsiDriver::enumMonitors(uint32_t index) {
+    return index == 0
+      ? getIosMonitor()
+      : nullptr;
+  }
+
+  HMONITOR IosWsiDriver::enumMonitors(const LUID *adapterLUID[], uint32_t numLUIDs, uint32_t index) {
+    return enumMonitors(index);
+  }
+
+  bool IosWsiDriver::getDisplayName(
+          HMONITOR         hMonitor,
+          WCHAR            (&Name)[32]) {
+    if (!isIosMonitor(hMonitor))
+      return false;
+
+    std::wstring name = L"iOS Display";
+
+    std::memset(Name, 0, sizeof(Name));
+    name.copy(Name, name.length(), 0);
+
+    return true;
+  }
+
+
+  bool IosWsiDriver::getDesktopCoordinates(
+          HMONITOR         hMonitor,
+          RECT*            pRect) {
+    if (!isIosMonitor(hMonitor))
+      return false;
+
+    uint32_t width  = 0;
+    uint32_t height = 0;
+    getMonitorSize(&width, &height);
+
+    pRect->left   = 0;
+    pRect->top    = 0;
+    pRect->right  = int32_t(width);
+    pRect->bottom = int32_t(height);
+
+    return true;
+  }
+
+
+  bool IosWsiDriver::getDisplayMode(
+          HMONITOR         hMonitor,
+          uint32_t         modeNumber,
+          WsiMode*         pMode) {
+    // The layer only ever has one mode: its current size at 60 Hz.
+    if (modeNumber != 0)
+      return false;
+
+    return getCurrentDisplayMode(hMonitor, pMode);
+  }
+
+
+  bool IosWsiDriver::getCurrentDisplayMode(
+          HMONITOR         hMonitor,
+          WsiMode*         pMode) {
+    if (!isIosMonitor(hMonitor))
+      return false;
+
+    uint32_t width  = 0;
+    uint32_t height = 0;
+    getMonitorSize(&width, &height);
+
+    pMode->width        = width;
+    pMode->height       = height;
+    pMode->refreshRate  = WsiRational{ 60 * 1000, 1000 };
+    pMode->bitsPerPixel = 32;
+    pMode->interlaced   = false;
+
+    return true;
+  }
+
+
+  bool IosWsiDriver::getDesktopDisplayMode(
+          HMONITOR         hMonitor,
+          WsiMode*         pMode) {
+    return getCurrentDisplayMode(hMonitor, pMode);
+  }
+
+  WsiEdidData IosWsiDriver::getMonitorEdid(HMONITOR hMonitor) {
+    Logger::err("getMonitorEdid not implemented on this platform.");
+    return {};
+  }
+
+}
+
+#endif
diff --git a/src/wsi/ios/wsi_platform_ios.h b/src/wsi/ios/wsi_platform_ios.h
new file mode 100644
index 0000000..cfbb557
--- /dev/null
+++ b/src/wsi/ios/wsi_platform_ios.h
@@ -0,0 +1,146 @@
+#pragma once
+
+/*
+ * iOS WSI backend.
+ *
+ * CONTRACT: On this backend the HWND passed into every WSI entry
+ * point IS a CAMetalLayer* that is created and owned by the hosting
+ * application shell. DXVK never retains, releases or resizes the
+ * layer; the shell must guarantee that the layer stays alive for as
+ * long as any DXVK swapchain that presents to it.
+ *
+ * There is no real window system to talk to: the backend exposes a
+ * single fake monitor whose desktop coordinates and display mode are
+ * derived from the layer's current size, and all window-management
+ * operations (resize, fullscreen transitions, ...) are benign no-ops
+ * that report success.
+ */
+
+#include "wsi/native_ios.h"
+
+#include "../wsi_platform.h"
+
+namespace dxvk::wsi {
+
+  // The one fake monitor exposed by this backend. Must be
+  // non-null so it doesn't read as "no monitor" to callers.
+  inline HMONITOR getIosMonitor() {
+    return reinterpret_cast<HMONITOR>(uintptr_t(1u));
+  }
+
+  inline bool isIosMonitor(HMONITOR hMonitor) {
+    return hMonitor == getIosMonitor();
+  }
+
+  class IosWsiDriver : public WsiDriver {
+  private:
+    // Most recently seen layer (weak, owned by the app shell).
+    // Used to answer monitor queries, which only receive the
+    // fake HMONITOR and therefore cannot carry the layer.
+    CAMetalLayer* m_layer = nullptr;
+
+    // Returns the layer behind hWindow and remembers
+    // it for subsequent monitor queries.
+    CAMetalLayer* getLayer(HWND hWindow);
+
+    // Pixel size of a layer: drawableSize if set,
+    // otherwise bounds.size * contentsScale.
+    static void getLayerPixelSize(
+            CAMetalLayer*    pLayer,
+            uint32_t*        pWidth,
+            uint32_t*        pHeight);
+
+    // Size of the fake monitor: the last known layer's pixel
+    // size, or a sane default if no layer was seen yet.
+    void getMonitorSize(
+            uint32_t*        pWidth,
+            uint32_t*        pHeight);
+
+  public:
+    // Platform
+    virtual std::vector<const char *> getInstanceExtensions();
+
+    // Monitor
+    virtual HMONITOR getDefaultMonitor();
+
+    virtual HMONITOR enumMonitors(uint32_t index);
+
+    virtual HMONITOR enumMonitors(const LUID *adapterLUID[], uint32_t numLUIDs, uint32_t index);
+
+    virtual bool getDisplayName(
+            HMONITOR         hMonitor,
+            WCHAR            (&Name)[32]);
+
+    virtual bool getDesktopCoordinates(
+            HMONITOR         hMonitor,
+            RECT*            pRect);
+
+    virtual bool getDisplayMode(
+            HMONITOR         hMonitor,
+            uint32_t         modeNumber,
+            WsiMode*         pMode);
+
+    virtual bool getCurrentDisplayMode(
+            HMONITOR         hMonitor,
+            WsiMode*         pMode);
+
+    virtual bool getDesktopDisplayMode(
+            HMONITOR         hMonitor,
+            WsiMode*         pMode);
+
+    virtual WsiEdidData getMonitorEdid(HMONITOR hMonitor);
+
+    // Window
+
+    virtual void getWindowSize(
+            HWND      hWindow,
+            uint32_t* pWidth,
+            uint32_t* pWeight);
+
+    virtual void resizeWindow(
+            HWND             hWindow,
+            DxvkWindowState* pState,
+            uint32_t         width,
+            uint32_t         weight);
+
+    virtual bool setWindowMode(
+            HMONITOR         hMonitor,
+            HWND             hWindow,
+            DxvkWindowState* pState,
+      const WsiMode&         mode);
+
+    virtual bool enterFullscreenMode(
+            HMONITOR         hMonitor,
+            HWND             hWindow,
+            DxvkWindowState* pState,
+            [[maybe_unused]]
+            bool             modeSwitch);
+
+    virtual bool leaveFullscreenMode(
+            HWND             hWindow,
+            DxvkWindowState* pState,
+            bool             restoreCoordinates);
+
+    virtual bool restoreDisplayMode();
+
+    virtual HMONITOR getWindowMonitor(HWND hWindow);
+
+    virtual bool isWindow(HWND hWindow);
+
+    virtual bool isMinimized(HWND hWindow);
+
+    virtual bool isOccluded(HWND hWindow);
+
+    virtual void updateFullscreenWindow(
+            HMONITOR hMonitor,
+            HWND     hWindow,
+            bool     forceTopmost);
+
+    virtual VkResult createSurface(
+            HWND                hWindow,
+            PFN_vkGetInstanceProcAddr pfnVkGetInstanceProcAddr,
+            VkInstance          instance,
+            VkSurfaceKHR*       pSurface);
+  };
+
+}
diff --git a/src/wsi/ios/wsi_platform_ios.mm b/src/wsi/ios/wsi_platform_ios.mm
new file mode 100644
index 0000000..86a5506
--- /dev/null
+++ b/src/wsi/ios/wsi_platform_ios.mm
@@ -0,0 +1,88 @@
+#if defined(DXVK_WSI_IOS)
+
+#include "wsi_platform_ios.h"
+
+#include "../../util/util_error.h"
+
+#include <vulkan/vulkan_metal.h>
+
+// windows_base.h defines this for the COM headers;
+// it would break @interface in Apple's frameworks.
+#undef interface
+
+#import <QuartzCore/CAMetalLayer.h>
+
+namespace dxvk::wsi {
+
+  CAMetalLayer* IosWsiDriver::getLayer(HWND hWindow) {
+    CAMetalLayer* layer = fromHwnd(hWindow);
+
+    if (layer != nullptr)
+      m_layer = layer;
+
+    return layer;
+  }
+
+
+  void IosWsiDriver::getLayerPixelSize(
+          CAMetalLayer*    pLayer,
+          uint32_t*        pWidth,
+          uint32_t*        pHeight) {
+    CGSize size = pLayer.drawableSize;
+
+    if (size.width < 1.0 || size.height < 1.0) {
+      CGSize bounds = pLayer.bounds.size;
+      CGFloat scale = pLayer.contentsScale;
+      size = CGSizeMake(bounds.width * scale, bounds.height * scale);
+    }
+
+    if (pWidth)
+      *pWidth = uint32_t(size.width);
+
+    if (pHeight)
+      *pHeight = uint32_t(size.height);
+  }
+
+
+  void IosWsiDriver::getMonitorSize(
+          uint32_t*        pWidth,
+          uint32_t*        pHeight) {
+    if (m_layer != nullptr) {
+      getLayerPixelSize(m_layer, pWidth, pHeight);
+      return;
+    }
+
+    // No layer seen yet, e.g. modes are being enumerated
+    // before device creation. Report a sane default.
+    if (pWidth)
+      *pWidth = 1920u;
+
+    if (pHeight)
+      *pHeight = 1080u;
+  }
+
+
+  std::vector<const char *> IosWsiDriver::getInstanceExtensions() {
+    return {
+      VK_KHR_SURFACE_EXTENSION_NAME,
+      VK_EXT_METAL_SURFACE_EXTENSION_NAME,
+    };
+  }
+
+  static bool createIosWsiDriver(WsiDriver **driver) {
+    try {
+      *driver = new IosWsiDriver();
+    } catch (const DxvkError& e) {
+      return false;
+    }
+    return true;
+  }
+
+  WsiBootstrap IosWSI = {
+    "iOS",
+    createIosWsiDriver
+  };
+
+}
+
+#endif
diff --git a/src/wsi/ios/wsi_window_ios.mm b/src/wsi/ios/wsi_window_ios.mm
new file mode 100644
index 0000000..3782241
--- /dev/null
+++ b/src/wsi/ios/wsi_window_ios.mm
@@ -0,0 +1,141 @@
+#if defined(DXVK_WSI_IOS)
+
+#include "../wsi_window.h"
+
+#include "wsi_platform_ios.h"
+
+#include "../../util/log/log.h"
+
+#include <windows.h>
+
+#include <vulkan/vulkan_metal.h>
+
+// windows_base.h defines this for the COM headers;
+// it would break @interface in Apple's frameworks.
+#undef interface
+
+#import <QuartzCore/CAMetalLayer.h>
+
+namespace dxvk::wsi {
+
+  void IosWsiDriver::getWindowSize(
+        HWND      hWindow,
+        uint32_t* pWidth,
+        uint32_t* pHeight) {
+    CAMetalLayer* layer = getLayer(hWindow);
+
+    if (layer != nullptr) {
+      getLayerPixelSize(layer, pWidth, pHeight);
+      return;
+    }
+
+    if (pWidth)
+      *pWidth = 0;
+
+    if (pHeight)
+      *pHeight = 0;
+  }
+
+
+  void IosWsiDriver::resizeWindow(
+          HWND             hWindow,
+          DxvkWindowState* pState,
+          uint32_t         Width,
+          uint32_t         Height) {
+    // The app shell owns the layer and its size.
+  }
+
+
+  bool IosWsiDriver::setWindowMode(
+          HMONITOR         hMonitor,
+          HWND             hWindow,
+          DxvkWindowState* pState,
+    const WsiMode&         pMode) {
+    // There are no display modes to switch to on iOS.
+    return true;
+  }
+
+
+  bool IosWsiDriver::enterFullscreenMode(
+          HMONITOR         hMonitor,
+          HWND             hWindow,
+          DxvkWindowState* pState,
+          bool             ModeSwitch) {
+    // The layer always covers whatever the app shell gave it.
+    return true;
+  }
+
+
+  bool IosWsiDriver::leaveFullscreenMode(
+          HWND             hWindow,
+          DxvkWindowState* pState,
+          bool             restoreCoordinates) {
+    return true;
+  }
+
+
+  bool IosWsiDriver::restoreDisplayMode() {
+    return true;
+  }
+
+
+  HMONITOR IosWsiDriver::getWindowMonitor(HWND hWindow) {
+    getLayer(hWindow);
+
+    return getIosMonitor();
+  }
+
+
+  bool IosWsiDriver::isWindow(HWND hWindow) {
+    return getLayer(hWindow) != nullptr;
+  }
+
+
+  bool IosWsiDriver::isMinimized(HWND hWindow) {
+    return false;
+  }
+
+
+  bool IosWsiDriver::isOccluded(HWND hWindow) {
+    return false;
+  }
+
+
+  void IosWsiDriver::updateFullscreenWindow(
+          HMONITOR hMonitor,
+          HWND     hWindow,
+          bool     forceTopmost) {
+    // Nothing to do on iOS.
+  }
+
+
+  VkResult IosWsiDriver::createSurface(
+          HWND                      hWindow,
+          PFN_vkGetInstanceProcAddr pfnVkGetInstanceProcAddr,
+          VkInstance                instance,
+          VkSurfaceKHR*             pSurface) {
+    CAMetalLayer* layer = getLayer(hWindow);
+
+    if (layer == nullptr) {
+      Logger::err("iOS WSI: createSurface: hWindow is not a CAMetalLayer.");
+      return VK_ERROR_INITIALIZATION_FAILED;
+    }
+
+    auto pfnVkCreateMetalSurfaceEXT = reinterpret_cast<PFN_vkCreateMetalSurfaceEXT>(
+      pfnVkGetInstanceProcAddr(instance, "vkCreateMetalSurfaceEXT"));
+
+    if (pfnVkCreateMetalSurfaceEXT == nullptr) {
+      Logger::err("iOS WSI: createSurface: vkCreateMetalSurfaceEXT not found. Is VK_EXT_metal_surface enabled?");
+      return VK_ERROR_EXTENSION_NOT_PRESENT;
+    }
+
+    VkMetalSurfaceCreateInfoEXT createInfo = { };
+    createInfo.sType  = VK_STRUCTURE_TYPE_METAL_SURFACE_CREATE_INFO_EXT;
+    createInfo.pLayer = layer;
+
+    return pfnVkCreateMetalSurfaceEXT(instance, &createInfo, nullptr, pSurface);
+  }
+
+}
+
+#endif

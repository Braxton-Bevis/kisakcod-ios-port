diff --git a/src/ZoneCodeGeneratorLib/Generating/Templates/ZoneLayoutManifestTemplate.cpp b/src/ZoneCodeGeneratorLib/Generating/Templates/ZoneLayoutManifestTemplate.cpp
new file mode 100644
index 0000000..1542297
--- /dev/null
+++ b/src/ZoneCodeGeneratorLib/Generating/Templates/ZoneLayoutManifestTemplate.cpp
@@ -0,0 +1,341 @@
+#include "ZoneLayoutManifestTemplate.h"
+
+#include "Domain/Computations/MemberComputations.h"
+#include "Domain/Computations/StructureComputations.h"
+#include "Domain/Definition/ArrayDeclarationModifier.h"
+#include "Domain/Definition/PointerDeclarationModifier.h"
+#include "Internal/BaseTemplate.h"
+#include "Utils/StringUtils.h"
+
+#include <algorithm>
+#include <cassert>
+#include <cctype>
+#include <format>
+#include <iomanip>
+#include <sstream>
+#include <unordered_map>
+
+namespace
+{
+    constexpr int TAG_MANIFEST = 1;
+
+    const char* DefinitionTypeName(const DataDefinitionType type)
+    {
+        switch (type)
+        {
+        case DataDefinitionType::STRUCT:
+            return "struct";
+        case DataDefinitionType::UNION:
+            return "union";
+        case DataDefinitionType::ENUM:
+            return "enum";
+        case DataDefinitionType::TYPEDEF:
+            return "typedef";
+        case DataDefinitionType::BASE_TYPE:
+            return "base";
+        case DataDefinitionType::FORWARD_DECLARATION:
+            return "forward-declaration";
+        }
+
+        return "unknown";
+    }
+
+    const char* BlockTypeName(const FastFileBlockType type)
+    {
+        switch (type)
+        {
+        case FastFileBlockType::TEMP:
+            return "temp";
+        case FastFileBlockType::RUNTIME:
+            return "runtime";
+        case FastFileBlockType::DELAY:
+            return "delay";
+        case FastFileBlockType::NORMAL:
+            return "normal";
+        }
+
+        return "unknown";
+    }
+
+    std::string Quote(const std::string& value)
+    {
+        std::ostringstream str;
+        str << std::quoted(value);
+        return str.str();
+    }
+
+    std::string Bool(const bool value)
+    {
+        return value ? "true" : "false";
+    }
+
+    class PerAsset final : BaseTemplate
+    {
+    public:
+        PerAsset(std::ostream& stream, const OncePerAssetRenderingContext& context)
+            : BaseTemplate(stream, context),
+              m_env(context)
+        {
+        }
+
+        void Manifest()
+        {
+            BuildStableNames();
+
+            std::vector<const RenderingUsedType*> structures;
+            structures.reserve(m_env.m_used_structures.size());
+            for (const auto* usedType : m_env.m_used_structures)
+                structures.push_back(usedType);
+
+            std::ranges::sort(structures,
+                              [this](const RenderingUsedType* lhs, const RenderingUsedType* rhs)
+                              {
+                                  const auto lhsName = StableName(lhs->m_info->m_definition);
+                                  const auto rhsName = StableName(rhs->m_info->m_definition);
+                                  if (lhsName != rhsName)
+                                      return lhsName < rhsName;
+                                  return lhs->m_info->m_definition->GetType() < rhs->m_info->m_definition->GetType();
+                              });
+
+            LINE("zone-layout-manifest-v1")
+            LINEF("game {}", Quote(m_env.m_game))
+            LINEF("word-size {}", m_env.m_pointer_size * 8u)
+            LINEF("pointer-size {}", m_env.m_pointer_size)
+            LINEF("asset {}", Quote(StableName(m_env.m_asset->m_definition)))
+            LINEF("asset-tag {}", Quote(m_env.m_asset->m_asset_name))
+            LINE("graph-semantics serialization-reachable")
+            LINE("foreign-assets terminal")
+            LINE("runtime-block-members terminal")
+            LINEF("structure-count {}", structures.size())
+
+            for (const auto* structure : structures)
+            {
+                LINE("")
+                Structure(*structure);
+            }
+        }
+
+    private:
+        static std::string AnonymousPathComponent(const DefinitionWithMembers* definition, const Variable* member, const size_t memberIndex)
+        {
+            const auto memberName = member->m_name.empty() ? std::to_string(memberIndex) : std::format("{}-{}", memberIndex, member->m_name);
+            return std::format("<anonymous-{}-{}>", DefinitionTypeName(definition->GetType()), memberName);
+        }
+
+        void BuildStableNames()
+        {
+            for (const auto* usedType : m_env.m_used_structures)
+            {
+                const auto* definition = usedType->m_info->m_definition;
+                if (!definition->IsAnonymous())
+                    m_stable_names.emplace(definition, definition->GetFullName());
+            }
+
+            bool changed;
+            do
+            {
+                changed = false;
+                for (const auto* usedType : m_env.m_used_structures)
+                {
+                    const auto* parent = usedType->m_info->m_definition;
+                    const auto foundParentName = m_stable_names.find(parent);
+                    if (foundParentName == m_stable_names.end())
+                        continue;
+
+                    const auto& members = usedType->m_info->m_ordered_members;
+                    for (auto memberIndex = 0u; memberIndex < members.size(); memberIndex++)
+                    {
+                        const auto* child = members[memberIndex]->m_type ? members[memberIndex]->m_type->m_definition : nullptr;
+                        if (child == nullptr || !child->IsAnonymous())
+                            continue;
+
+                        const auto candidate = std::format(
+                            "{}::{}", foundParentName->second, AnonymousPathComponent(child, members[memberIndex]->m_member, memberIndex));
+                        const auto foundChildName = m_stable_names.find(child);
+                        if (foundChildName == m_stable_names.end())
+                        {
+                            m_stable_names.emplace(child, candidate);
+                            changed = true;
+                        }
+                        else if (candidate < foundChildName->second)
+                        {
+                            foundChildName->second = candidate;
+                            changed = true;
+                        }
+                    }
+                }
+            } while (changed);
+        }
+
+        std::string StableName(const DataDefinition* definition) const
+        {
+            const auto* definitionWithMembers = dynamic_cast<const DefinitionWithMembers*>(definition);
+            if (definitionWithMembers == nullptr || !definitionWithMembers->IsAnonymous())
+                return definition->GetFullName();
+
+            const auto foundName = m_stable_names.find(definitionWithMembers);
+            return foundName == m_stable_names.end() ? "<anonymous-unreached>" : foundName->second;
+        }
+
+        static std::string ExpressionSafeName(const std::string& name)
+        {
+            std::string result;
+            result.reserve(name.size());
+            for (const auto c : name)
+                result.push_back(isalnum(static_cast<unsigned char>(c)) ? c : '_');
+            return result;
+        }
+
+        std::string Evaluation(const IEvaluation* evaluation) const
+        {
+            if (evaluation == nullptr)
+                return "-";
+
+            auto rendered = MakeEvaluation(evaluation);
+            for (const auto& [definition, stableName] : m_stable_names)
+            {
+                if (!definition->IsAnonymous())
+                    continue;
+
+                const auto randomName = std::format("var{}", definition->m_name);
+                const auto normalizedName = std::format("var{}", ExpressionSafeName(stableName));
+                for (auto position = rendered.find(randomName); position != std::string::npos; position = rendered.find(randomName, position + normalizedName.size()))
+                    rendered.replace(position, randomName.size(), normalizedName);
+            }
+
+            return Quote(rendered);
+        }
+
+        static std::string Block(const FastFileBlock* block)
+        {
+            if (block == nullptr)
+                return "-";
+
+            return std::format("{}:index={}:type={}:default={}", Quote(block->m_name), block->m_index, BlockTypeName(block->m_type), Bool(block->m_is_default));
+        }
+
+        void Structure(const RenderingUsedType& usedType)
+        {
+            const auto* info = usedType.m_info;
+            const auto* definition = info->m_definition;
+            const StructureComputations computations(info);
+            const auto isForeignAsset = computations.IsAsset() && !usedType.m_is_context_asset;
+
+            LINEF("structure {}", Quote(StableName(definition)))
+            LINEF("  kind {}", DefinitionTypeName(definition->GetType()))
+            LINEF("  size {}", definition->GetSize())
+            LINEF("  align {}", definition->GetAlignment())
+            LINEF("  force-align {}", Bool(definition->GetForceAlignment()))
+            LINEF("  asset-tag {}", info->m_asset_name.empty() ? "-" : Quote(info->m_asset_name))
+            LINEF("  context-asset {}", Bool(usedType.m_is_context_asset))
+            LINEF("  foreign-asset {}", Bool(isForeignAsset))
+            LINEF("  allocation-align {}", Evaluation(info->m_alloc_alignment.get()))
+            LINEF("  block {}", Block(info->m_block))
+            LINEF("  leaf {}", Bool(info->m_is_leaf))
+            LINEF("  requires-marking {}", Bool(info->m_requires_marking))
+            LINEF("  cross-platform-layout-match {}", Bool(info->m_has_matching_cross_platform_structure))
+            LINEF("  embedded-reference {}", Bool(info->m_embedded_reference_exists))
+            LINEF("  non-embedded-reference {}", Bool(info->m_non_embedded_reference_exists))
+            LINEF("  single-pointer-reference {}", Bool(info->m_single_pointer_reference_exists))
+            LINEF("  array-pointer-reference {}", Bool(info->m_array_pointer_reference_exists))
+            LINEF("  array-reference {}", Bool(info->m_array_reference_exists))
+            LINEF("  non-default-normal-block-reference {}", Bool(info->m_reference_from_non_default_normal_block_exists))
+            LINEF("  member-count {}", info->m_ordered_members.size())
+
+            for (auto memberIndex = 0u; memberIndex < info->m_ordered_members.size(); memberIndex++)
+                Member(memberIndex, *info->m_ordered_members[memberIndex]);
+
+            LINE("end-structure")
+        }
+
+        void Member(const size_t memberIndex, const MemberInformation& info)
+        {
+            const auto* variable = info.m_member;
+            const auto* declaration = variable->m_type_declaration.get();
+            const MemberComputations computations(&info);
+
+            LINEF("  member {} {}", memberIndex, Quote(variable->m_name))
+            LINEF("    type {}", Quote(StableName(declaration->m_type)))
+            LINEF("    type-kind {}", DefinitionTypeName(declaration->m_type->GetType()))
+            LINEF("    offset {}", variable->m_offset)
+            LINEF("    size {}", declaration->GetSize())
+            LINEF("    align {}", declaration->GetAlignment())
+            LINEF("    force-align {}", Bool(declaration->GetForceAlignment()))
+            LINEF("    alignment-override {}", variable->m_has_alignment_override ? std::to_string(variable->m_alignment_override) : "-")
+            LINEF("    const {}", Bool(declaration->m_is_const))
+            LINEF("    bit-size {}", declaration->m_has_custom_bit_size ? std::to_string(declaration->m_custom_bit_size) : "-")
+            LINEF("    condition {}", Evaluation(info.m_condition.get()))
+            LINEF("    ignored {}", Bool(computations.ShouldIgnore()))
+            LINEF("    allocation-align {}", Evaluation(info.m_alloc_alignment.get()))
+            LINEF("    block {}", Block(info.m_fast_file_block))
+            LINEF("    string {}", Bool(info.m_is_string))
+            LINEF("    script-string {}", Bool(info.m_is_script_string))
+            LINEF("    reusable {}", Bool(info.m_is_reusable))
+            LINEF("    leaf {}", Bool(info.m_is_leaf))
+            LINEF("    asset-ref {}", info.m_asset_ref.empty() ? "-" : Quote(info.m_asset_ref))
+            LINEF("    pointer-depth {}", computations.GetPointerDepth())
+            LINEF("    embedded-reference {}", Bool(!computations.ContainsNonEmbeddedReference()))
+            LINEF("    single-pointer-reference {}", Bool(computations.ContainsSinglePointerReference()))
+            LINEF("    array-pointer-reference {}", Bool(computations.ContainsArrayPointerReference()))
+            LINEF("    pointer-array-reference {}", Bool(computations.ContainsPointerArrayReference()))
+            LINEF("    array-reference {}", Bool(computations.ContainsArrayReference()))
+            LINEF("    dynamic {}", Bool(computations.IsDynamicMember()))
+            LINEF("    runtime-block {}", Bool(computations.IsInRuntimeBlock()))
+            LINEF("    modifier-count {}", declaration->m_declaration_modifiers.size())
+
+            for (auto modifierIndex = 0u; modifierIndex < declaration->m_declaration_modifiers.size(); modifierIndex++)
+                Modifier(modifierIndex, *declaration->m_declaration_modifiers[modifierIndex]);
+
+            LINE("  end-member")
+        }
+
+        void Modifier(const size_t modifierIndex, const DeclarationModifier& modifier)
+        {
+            if (modifier.GetType() == DeclarationModifierType::ARRAY)
+            {
+                const auto& array = dynamic_cast<const ArrayDeclarationModifier&>(modifier);
+                LINEF("    modifier {} array", modifierIndex)
+                LINEF("      size {}", array.m_size)
+                LINEF("      dynamic-size {}", Evaluation(array.m_dynamic_size_evaluation.get()))
+                LINEF("      dynamic-count {}", Evaluation(array.m_dynamic_count_evaluation.get()))
+            }
+            else
+            {
+                const auto& pointer = dynamic_cast<const PointerDeclarationModifier&>(modifier);
+                LINEF("    modifier {} pointer", modifierIndex)
+                LINEF("      count {}", Evaluation(pointer.GetCountEvaluation()))
+                LINEF("      count-is-array {}", Bool(pointer.CountEvaluationIsArray()))
+                LINEF("      indexed-count-count {}", pointer.m_count_evaluation_by_array_index.size())
+                for (auto countIndex = 0u; countIndex < pointer.m_count_evaluation_by_array_index.size(); countIndex++)
+                {
+                    LINEF("      indexed-count {} {}", countIndex, Evaluation(pointer.m_count_evaluation_by_array_index[countIndex].get()))
+                }
+            }
+
+            LINE("    end-modifier")
+        }
+
+        const OncePerAssetRenderingContext& m_env;
+        std::unordered_map<const DefinitionWithMembers*, std::string> m_stable_names;
+    };
+} // namespace
+
+std::vector<CodeTemplateFile> ZoneLayoutManifestTemplate::GetFilesToRenderOncePerAsset(const OncePerAssetRenderingContext& context)
+{
+    auto assetName = context.m_asset->m_definition->m_name;
+    utils::MakeStringLowerCase(assetName);
+
+    auto gameName = context.m_game;
+    utils::MakeStringLowerCase(gameName);
+
+    return {CodeTemplateFile(std::format("ZoneLayoutManifest/{}/{}_{}.layout", gameName, gameName, assetName), TAG_MANIFEST)};
+}
+
+void ZoneLayoutManifestTemplate::RenderOncePerAssetFile(std::ostream& stream,
+                                                        const CodeTemplateFileTag fileTag,
+                                                        const OncePerAssetRenderingContext& context)
+{
+    assert(fileTag == TAG_MANIFEST);
+    if (fileTag == TAG_MANIFEST)
+        PerAsset(stream, context).Manifest();
+}
